
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>海外留学診断 | Your Journey Awaits</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=Noto+Serif+JP:wght@300;400;600&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --rose: #E8AFAF;
            --rose-light: #F5DADA;
            --rose-deep: #C4847A;
            --sand: #F5EDE3;
            --sand-mid: #EAD9C8;
            --cream: #FDFAF7;
            --ivory: #F9F4EE;
            --text: #3A2E2A;
            --text-mid: #7A6A63;
            --text-light: #B4A59E;
            --sage: #9FAF94;
            --sage-light: #D4E0CE;
            --gold: #C49A5A;
            --gold-light: #E8D5B0;
            --sky: #A8C4CF;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'DM Sans', 'Noto Sans JP', sans-serif;
            background: var(--sand);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ── Background Decoration ── */
        body::before {
            content: '';
            position: fixed;
            top: -200px; right: -200px;
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(232,175,175,0.25) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }
        body::after {
            content: '';
            position: fixed;
            bottom: -150px; left: -150px;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(159,175,148,0.2) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        /* ── Layout ── */
        .page {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 40px 20px 60px;
        }

        .card {
            background: var(--cream);
            max-width: 580px;
            width: 100%;
            border-radius: 36px;
            padding: 56px 48px;
            box-shadow:
                0 2px 4px rgba(58,46,42,0.04),
                0 8px 24px rgba(58,46,42,0.06),
                0 32px 80px rgba(58,46,42,0.08);
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--rose) 0%, var(--gold) 50%, var(--sage) 100%);
        }

        /* ── Header ── */
        .site-header {
            text-align: center;
            margin-bottom: 36px;
        }

        .logo-mark {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.75rem;
            font-weight: 400;
            letter-spacing: 0.3em;
            color: var(--text-light);
            text-transform: uppercase;
            margin-bottom: 16px;
        }

        .logo-mark::before,
        .logo-mark::after {
            content: '';
            display: block;
            width: 30px;
            height: 1px;
            background: var(--rose);
        }

        h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.6rem;
            font-weight: 300;
            letter-spacing: 0.05em;
            color: var(--text);
            line-height: 1.1;
            margin-bottom: 10px;
        }

        h1 em {
            font-style: italic;
            color: var(--rose-deep);
        }

        .tagline {
            font-size: 0.78rem;
            color: var(--text-light);
            letter-spacing: 0.12em;
            font-weight: 300;
        }

        /* ── Progress ── */
        .progress-wrap {
            margin: 28px 0 36px;
        }

        .progress-numbers {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .q-count {
            font-size: 0.72rem;
            color: var(--text-light);
            letter-spacing: 0.08em;
        }

        .q-percent {
            font-family: 'Cormorant Garamond', serif;
            font-size: 0.85rem;
            color: var(--rose-deep);
        }

        .progress-track {
            height: 3px;
            background: var(--sand-mid);
            border-radius: 2px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--rose) 0%, var(--rose-deep) 100%);
            border-radius: 2px;
            transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            width: 0%;
        }

        /* ── Question ── */
        .q-num-label {
            display: block;
            font-size: 0.68rem;
            letter-spacing: 0.2em;
            color: var(--rose-deep);
            text-align: center;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .q-text {
            font-family: 'Noto Serif JP', serif;
            font-size: 1.22rem;
            text-align: center;
            line-height: 1.7;
            color: var(--text);
            margin-bottom: 32px;
            font-weight: 300;
        }

        /* ── Options ── */
        .options-grid {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .opt-btn {
            position: relative;
            background: var(--ivory);
            border: 1.5px solid var(--sand-mid);
            border-radius: 18px;
            padding: 18px 22px 18px 52px;
            font-family: 'Noto Sans JP', sans-serif;
            font-size: 0.88rem;
            font-weight: 300;
            color: var(--text);
            cursor: pointer;
            text-align: left;
            line-height: 1.5;
            transition: all 0.25s ease;
            overflow: hidden;
        }

        .opt-btn::before {
            content: attr(data-letter);
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--sand-mid);
            color: var(--text-mid);
            font-size: 0.72rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Cormorant Garamond', serif;
            letter-spacing: 0;
            transition: all 0.25s ease;
        }

        /* Hack for ::before content with flex */
        .opt-btn::before { display: grid; place-items: center; }

        .opt-btn:hover {
            border-color: var(--rose);
            background: #FEF8F8;
            transform: translateX(5px);
            box-shadow: 0 4px 20px rgba(232,175,175,0.2);
        }

        .opt-btn:hover::before {
            background: var(--rose);
            color: white;
        }

        .opt-btn:active {
            transform: translateX(5px) scale(0.98);
        }

        /* ── Notice ── */
        .notice-box {
            margin-top: 28px;
            padding: 16px 20px;
            background: var(--ivory);
            border-radius: 14px;
            border-left: 3px solid var(--rose-light);
            font-size: 0.72rem;
            color: var(--text-light);
            line-height: 1.8;
        }

        /* ── Decorative flower ── */
        .deco-flower {
            text-align: center;
            font-size: 1.4rem;
            margin-bottom: 8px;
            opacity: 0.5;
        }

        /* ── RESULT ── */
        #result-screen {
            display: none;
        }

        .result-hero {
            text-align: center;
            margin-bottom: 32px;
            position: relative;
        }

        .result-badge {
            display: inline-block;
            background: linear-gradient(135deg, var(--rose-light), var(--gold-light));
            color: var(--rose-deep);
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 6px 18px;
            border-radius: 50px;
            margin-bottom: 18px;
        }

        .result-plan-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 300;
            color: var(--text);
            line-height: 1.3;
            margin-bottom: 6px;
        }

        .result-plan-title strong {
            font-weight: 600;
            color: var(--rose-deep);
        }

        .result-subtitle {
            font-size: 0.78rem;
            color: var(--text-light);
            letter-spacing: 0.08em;
        }

        /* ── Score Bar ── */
        .score-section {
            background: var(--ivory);
            border-radius: 20px;
            padding: 22px 24px;
            margin-bottom: 24px;
        }

        .score-section-title {
            font-size: 0.68rem;
            letter-spacing: 0.18em;
            color: var(--text-light);
            text-transform: uppercase;
            margin-bottom: 16px;
        }

        .score-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 10px;
        }

        .score-label {
            font-size: 0.78rem;
            color: var(--text-mid);
            width: 110px;
            flex-shrink: 0;
        }

        .score-bar-track {
            flex: 1;
            height: 6px;
            background: var(--sand-mid);
            border-radius: 3px;
            overflow: hidden;
        }

        .score-bar-fill {
            height: 100%;
            border-radius: 3px;
            width: 0%;
            transition: width 1s cubic-bezier(0.4, 0, 0.2, 1) 0.3s;
        }

        .score-val {
            font-size: 0.75rem;
            color: var(--text-mid);
            width: 30px;
            text-align: right;
            flex-shrink: 0;
        }

        /* ── Counseling Note ── */
        .counseling-card {
            background: linear-gradient(135deg, #FEF8F8 0%, #FBF6F0 100%);
            border-radius: 20px;
            padding: 24px 26px;
            margin-bottom: 24px;
            border: 1px solid var(--rose-light);
            position: relative;
        }

        .counseling-card::before {
            content: '＂';
            position: absolute;
            top: -5px;
            left: 20px;
            font-family: 'Cormorant Garamond', serif;
            font-size: 3rem;
            color: var(--rose-light);
            line-height: 1;
        }

        .counseling-label {
            font-size: 0.65rem;
            letter-spacing: 0.2em;
            color: var(--rose-deep);
            font-weight: 500;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .counseling-text {
            font-family: 'Noto Serif JP', serif;
            font-size: 0.9rem;
            line-height: 1.9;
            color: var(--text);
            font-weight: 300;
        }

        /* ── Plan Details ── */
        .plan-detail {
            margin-bottom: 24px;
        }

        .plan-detail-title {
            font-size: 0.68rem;
            letter-spacing: 0.18em;
            color: var(--text-light);
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .plan-item {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            padding: 16px;
            background: var(--ivory);
            border-radius: 14px;
            margin-bottom: 8px;
            border: 1px solid transparent;
            transition: border-color 0.2s;
        }

        .plan-item:hover {
            border-color: var(--rose-light);
        }

        .plan-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .plan-item-content {}

        .plan-item-name {
            font-size: 0.88rem;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 3px;
        }

        .plan-item-desc {
            font-size: 0.76rem;
            color: var(--text-light);
            line-height: 1.5;
        }

        /* ── Cities ── */
        .cities-section {
            margin-bottom: 28px;
        }

        .cities-title {
            font-size: 0.68rem;
            letter-spacing: 0.18em;
            color: var(--text-light);
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .cities-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .city-card {
            background: var(--ivory);
            border-radius: 16px;
            padding: 16px 12px;
            text-align: center;
            border: 1px solid var(--sand-mid);
            transition: all 0.25s;
        }

        .city-card:hover {
            border-color: var(--rose);
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(232,175,175,0.15);
        }

        .city-flag { font-size: 1.4rem; margin-bottom: 6px; }
        .city-name {
            font-size: 0.78rem;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 3px;
        }
        .city-tag {
            font-size: 0.64rem;
            color: var(--text-light);
        }

        /* ── Budget & Duration ── */
        .info-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 28px;
        }

        .info-chip {
            background: var(--ivory);
            border-radius: 16px;
            padding: 18px 16px;
            text-align: center;
        }

        .info-chip-label {
            font-size: 0.64rem;
            letter-spacing: 0.15em;
            color: var(--text-light);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .info-chip-value {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.3rem;
            color: var(--text);
            font-weight: 400;
        }

        /* ── Warning / Tips ── */
        .tips-card {
            background: linear-gradient(135deg, #F5F9F4 0%, #EDF3F0 100%);
            border-radius: 16px;
            padding: 18px 20px;
            margin-bottom: 24px;
            border-left: 3px solid var(--sage);
        }

        .tips-label {
            font-size: 0.65rem;
            letter-spacing: 0.18em;
            color: var(--sage);
            text-transform: uppercase;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .tips-text {
            font-size: 0.82rem;
            color: var(--text-mid);
            line-height: 1.7;
        }

        /* ── CTA ── */
        .cta-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-top: 10px;
        }

        .cta-primary {
            display: block;
            background: linear-gradient(135deg, var(--text) 0%, #5A4440 100%);
            color: white;
            text-align: center;
            padding: 20px;
            border-radius: 50px;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            letter-spacing: 0.06em;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .cta-primary::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--rose-deep) 0%, #8B5E5A 100%);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .cta-primary:hover::before { opacity: 1; }
        .cta-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(58,46,42,0.2); }
        .cta-primary span { position: relative; z-index: 1; }

        .cta-secondary {
            display: block;
            background: transparent;
            color: var(--text-light);
            text-align: center;
            padding: 14px;
            border-radius: 50px;
            border: 1.5px solid var(--sand-mid);
            text-decoration: none;
            font-size: 0.82rem;
            letter-spacing: 0.05em;
            cursor: pointer;
            transition: all 0.25s;
        }

        .cta-secondary:hover {
            border-color: var(--rose);
            color: var(--rose-deep);
        }

        /* ── Animations ── */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes scaleIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }

        .fade-up { animation: fadeUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
        .scale-in { animation: scaleIn 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards; }

        /* stagger */
        .stagger > * { opacity: 0; }
        .stagger > *:nth-child(1) { animation: fadeUp 0.5s 0.05s ease forwards; }
        .stagger > *:nth-child(2) { animation: fadeUp 0.5s 0.12s ease forwards; }
        .stagger > *:nth-child(3) { animation: fadeUp 0.5s 0.19s ease forwards; }
        .stagger > *:nth-child(4) { animation: fadeUp 0.5s 0.26s ease forwards; }

        /* ── Footer ── */
        .footer-note {
            text-align: center;
            font-size: 0.68rem;
            color: var(--text-light);
            margin-top: 24px;
            line-height: 1.8;
        }

        @media (max-width: 520px) {
            .card { padding: 44px 28px; border-radius: 28px; }
            h1 { font-size: 2rem; }
            .cities-grid { grid-template-columns: 1fr 1fr; }
            .info-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
<div class="page">
<div class="card">

    <!-- ===== QUIZ SCREEN ===== -->
    <div id="quiz-screen">
        <header class="site-header">
            <div class="logo-mark">Study Abroad</div>
            <h1>Find Your <em>Journey</em></h1>
            <p class="tagline">海外留学・スタイル診断 ― オーストラリア / カナダ / フィリピン専門</p>
        </header>

        <div class="progress-wrap">
            <div class="progress-numbers">
                <span class="q-count" id="q-count">Q 1 / 8</span>
                <span class="q-percent" id="q-percent">0%</span>
            </div>
            <div class="progress-track">
                <div class="progress-fill" id="progress-fill"></div>
            </div>
        </div>

        <div id="q-content"></div>

        <div class="notice-box">
            <div class="deco-flower">✦</div>
            直感で、今の自分に一番近いものを選んでください。答えに正解はありません。<br>
            診断結果はあなたへの<strong>プロのアドバイス</strong>として活用してください。
        </div>
    </div>

    <!-- ===== RESULT SCREEN ===== -->
    <div id="result-screen">

        <div class="result-hero">
            <div class="result-badge" id="res-badge">Your Best Plan</div>
            <div class="result-plan-title" id="res-title"></div>
            <div class="result-subtitle" id="res-subtitle"></div>
        </div>

        <!-- Score Bars -->
        <div class="score-section" id="score-section">
            <div class="score-section-title">あなたの適性スコア</div>
            <div id="score-bars"></div>
        </div>

        <!-- Counseling Note -->
        <div class="counseling-card">
            <div class="counseling-label">Counselor's Note</div>
            <div class="counseling-text" id="res-counseling"></div>
        </div>

        <!-- Plan Detail -->
        <div class="plan-detail">
            <div class="plan-detail-title">おすすめプラン詳細</div>
            <div id="res-plan-items"></div>
        </div>

        <!-- Cities -->
        <div class="cities-section">
            <div class="cities-title">Recommended Cities</div>
            <div class="cities-grid" id="res-cities"></div>
        </div>

        <!-- Budget & Duration -->
        <div class="info-row" id="res-info-row"></div>

        <!-- Tips -->
        <div class="tips-card" id="res-tips">
            <div class="tips-label">✦ Success Point</div>
            <div class="tips-text" id="res-tips-text"></div>
        </div>

        <!-- CTA -->
        <div class="cta-group">
            <a href="#" class="cta-primary"><span>🌿 無料カウンセリングに申し込む</span></a>
            <button class="cta-secondary" onclick="resetQuiz()">もう一度診断する</button>
        </div>

        <p class="footer-note">
            ※診断結果はあくまでも目安です。最適なプランは個人の状況によって異なります。<br>
            専門カウンセラーに相談することをおすすめします。
        </p>
    </div>

</div><!-- /card -->
</div><!-- /page -->

<script>
const questions = [
    {
        q: "今、あなたの年齢は？",
        sub: "渡航ビザの種類や選択肢が変わります",
        options: [
            { text: "18〜22歳 ── 学生・新卒ステージ", v: { age: 'young' } },
            { text: "23〜26歳 ── 第二新卒・キャリア模索中", v: { age: 'mid' } },
            { text: "27〜30歳 ── 転換期・ギリホリを検討中", v: { age: 'late' } },
            { text: "31歳以上 ── 大人の学び・専門スキル強化", v: { age: 'adult' } }
        ]
    },
    {
        q: "今の英語力を正直に教えてください",
        sub: "適切なコースとルートを提案するために必要です",
        options: [
            { text: "ほぼゼロ…中学レベルも怪しい", v: { eng: 'zero' } },
            { text: "基礎はある。でも会話は全く自信ない", v: { eng: 'basic' } },
            { text: "日常会話ならなんとかなる（英検2級程度）", v: { eng: 'mid' } },
            { text: "ビジネスや専門的な場面でも使いたい", v: { eng: 'high' } }
        ]
    },
    {
        q: "渡航の一番の目的は何ですか？",
        sub: "複数ある場合は「最も強い動機」を選んでください",
        options: [
            { text: "英語力を根本から鍛え直したい", v: { goal: 'english' } },
            { text: "海外で働いてお金を稼ぎたい・貯めたい", v: { goal: 'work' } },
            { text: "海外の資格・学位でキャリアをアップしたい", v: { goal: 'career' } },
            { text: "自分を変えたい・リセットして新しい自分になりたい", v: { goal: 'reset' } }
        ]
    },
    {
        q: "用意できる自己資金はどのくらい？",
        sub: "渡航前の貯金額（渡航費・学費・生活費の合計）",
        options: [
            { text: "50〜100万円未満（できるだけ節約したい）", v: { budget: 'low' } },
            { text: "100〜200万円（標準的な予算）", v: { budget: 'mid' } },
            { text: "200〜350万円（しっかり投資したい）", v: { budget: 'high' } },
            { text: "350万円以上（学位・永住権も視野に入れている）", v: { budget: 'pro' } }
        ]
    },
    {
        q: "希望する滞在期間は？",
        sub: "仕事・学校などの事情も考慮して選んでください",
        options: [
            { text: "3〜6ヶ月（短期集中でいい）", v: { dur: 'short' } },
            { text: "6ヶ月〜1年（一般的な期間）", v: { dur: 'mid' } },
            { text: "1〜2年（じっくり腰を据えたい）", v: { dur: 'long' } },
            { text: "2年以上・移住も視野（本気でキャリアを作りたい）", v: { dur: 'pr' } }
        ]
    },
    {
        q: "あなたの性格に最も近いのは？",
        sub: "向いている環境・サポート体制を判断します",
        options: [
            { text: "行動力抜群！まず飛び込んで考えるタイプ", v: { type: 'active' } },
            { text: "計画派。準備を完璧にしてから動きたい", v: { type: 'planner' } },
            { text: "流されやすい。誰かのサポートや仲間が必要", v: { type: 'passive' } },
            { text: "マイペース。一人でコツコツ進めるのが好き", v: { type: 'solo' } }
        ]
    },
    {
        q: "どんな生活環境が理想？",
        sub: "都市や地域の候補を絞ります",
        options: [
            { text: "オシャレなカフェ・ショッピングが充実した大都会", v: { env: 'urban' } },
            { text: "海や自然があるゆったりとしたリゾート系", v: { env: 'nature' } },
            { text: "日本人が少なく現地に溶け込みやすい地方都市", v: { env: 'local' } },
            { text: "安全で日本人コミュニティがある程度ある環境", v: { env: 'safe' } }
        ]
    },
    {
        q: "帰国後、どうなっていたい？",
        sub: "逆算してベストなプランを提案します",
        options: [
            { text: "英語を武器に転職・年収アップを実現したい", v: { after: 'job' } },
            { text: "海外での貯金＋経験で、次のステージに進みたい", v: { after: 'money' } },
            { text: "専門資格や学歴を取得してスキルを証明したい", v: { after: 'degree' } },
            { text: "内面の成長・価値観の変化を手に入れたい", v: { after: 'growth' } }
        ]
    }
];

let current = 0;
let answers = {};

function render() {
    const content = document.getElementById('q-content');
    content.style.opacity = '0';
    content.style.transform = 'translateY(12px)';

    setTimeout(() => {
        const d = questions[current];
        content.innerHTML = `
            <span class="q-num-label">Question ${current + 1} of ${questions.length}</span>
            <div class="q-text">${d.q}${d.sub ? `<br><small style="font-size:0.72rem;color:var(--text-light);font-family:'DM Sans',sans-serif;">${d.sub}</small>` : ''}</div>
            <div class="options-grid stagger">
                ${d.options.map((o, i) => `
                    <button class="opt-btn" data-letter="${String.fromCharCode(65+i)}" onclick="next(${i})">${o.text}</button>
                `).join('')}
            </div>
        `;
        content.style.transition = 'all 0.4s cubic-bezier(0.4,0,0.2,1)';
        content.style.opacity = '1';
        content.style.transform = 'translateY(0)';

        const pct = Math.round((current / questions.length) * 100);
        document.getElementById('progress-fill').style.width = pct + '%';
        document.getElementById('q-count').textContent = `Q ${current + 1} / ${questions.length}`;
        document.getElementById('q-percent').textContent = pct + '%';
    }, 150);
}

function next(i) {
    answers = { ...answers, ...questions[current].options[i].v };
    current++;
    if (current < questions.length) render();
    else showResult();
}

function showResult() {
    document.getElementById('progress-fill').style.width = '100%';
    document.getElementById('q-percent').textContent = '100%';

    setTimeout(() => {
        document.getElementById('quiz-screen').style.display = 'none';
        const rs = document.getElementById('result-screen');
        rs.style.display = 'block';
        rs.style.opacity = '0';
        setTimeout(() => {
            rs.style.transition = 'opacity 0.6s ease';
            rs.style.opacity = '1';
        }, 50);
        buildResult();
    }, 500);
}

function buildResult() {
    const a = answers;

    // ─── 判定ロジック ───
    let plan = {};

    // 1. 大人の本格進学（31歳以上 or 予算350万以上 or キャリア+学位志向）
    if (a.age === 'adult' || a.budget === 'pro' || (a.goal === 'career' && a.after === 'degree')) {
        plan = {
            badge: '本格キャリアアッププラン',
            title: '大人の本気進学',
            titleSub: 'TAFE / カレッジ専門留学プラン',
            subtitle: 'オーストラリア / カナダ ― 専門資格取得コース',
            counseling: `年齢や資金・目標を見ると、単なるワーホリや語学留学では物足りません。現地の州立TAFE（職業訓練校）やカレッジで<strong>国際的に認められた専門資格</strong>を取得し、帰国後のキャリアアップ・現地就職・永住権申請を視野に入れたプランが最適です。特に看護・IT・調理・ビジネス系は就労ビザへの移行率が高く、<strong>しっかり「形」に残る留学</strong>が実現できます。`,
            scores: [
                { label: 'キャリア向上度', val: 95, color: 'var(--rose-deep)' },
                { label: '英語上達速度', val: 80, color: 'var(--gold)' },
                { label: '収入獲得力', val: 75, color: 'var(--sage)' },
                { label: '自己成長度', val: 90, color: 'var(--sky)' }
            ],
            planItems: [
                { icon: '🎓', bg: '#FEF1F1', name: 'TAFE / カレッジ入学', desc: '政府認定の職業訓練。看護・IT・調理・ビジネス等の専門資格が取得可能' },
                { icon: '💼', bg: '#F5F9F4', name: '就労ビザ移行サポート', desc: '卒業後は就労ビザ（482/485等）申請で現地でのキャリアが開ける' },
                { icon: '🌏', bg: '#F0F5F9', name: '永住権（PR）への道', desc: '特定職種は雇用主スポンサーを通じてPR申請も現実的に検討できる' }
            ],
            cities: [
                { flag: '🇦🇺', name: 'シドニー', tag: 'IT・看護に強い' },
                { flag: '🇦🇺', name: 'メルボルン', tag: '大学・TAFE集中' },
                { flag: '🇨🇦', name: 'トロント', tag: 'ビジネス留学の聖地' }
            ],
            budget: '200〜400万円',
            duration: '1〜2年+',
            tips: '渡航前に英語力をある程度仕上げておくと、入学できるコースの幅が大きく広がります。フィリピン3ヶ月→オーストラリア進学の2カ国プランも人気です。'
        };
    }
    // 2. フィリピン→豪加 2カ国プラン（英語ゼロ or 予算少 or 心細いタイプ）
    else if (a.eng === 'zero' || (a.eng === 'basic' && a.type === 'passive') || (a.budget === 'low' && a.eng !== 'high')) {
        plan = {
            badge: '英語力ゼロからでもOK',
            title: 'フィリピン → 豪加',
            titleSub: '2カ国留学スタートダッシュプラン',
            subtitle: 'セブ島3ヶ月集中 → オーストラリア or カナダへ',
            counseling: `英語力に不安があるまま欧米に直行するのはリスクが高い選択です。まず<strong>物価が安く・マンツーマン授業が充実したフィリピン・セブ島</strong>で3〜4ヶ月間スパルタ英語漬け生活を。授業料・生活費合わせて月5〜7万円と激安なので貯金を温存しながら英語の基礎を固められます。自信がついてから豪州・カナダへ渡れば、<strong>現地での吸収速度が段違い</strong>。コスパ最強のルートです。`,
            scores: [
                { label: '英語上達速度', val: 98, color: 'var(--rose-deep)' },
                { label: 'コストパフォーマンス', val: 92, color: 'var(--gold)' },
                { label: '心理的安全性', val: 85, color: 'var(--sage)' },
                { label: 'キャリア向上度', val: 70, color: 'var(--sky)' }
            ],
            planItems: [
                { icon: '🇵🇭', bg: '#FFF8E7', name: 'フィリピン・セブ島 3〜4ヶ月', desc: 'スパルタ語学学校でマンツーマン授業。月6〜8万円で英語基礎を徹底的に固める' },
                { icon: '✈️', bg: '#FEF1F1', name: 'オーストラリア or カナダへ渡航', desc: '英語力がついた状態で渡航。語学学校→バイト→ローカルジョブへスムーズに移行' },
                { icon: '💰', bg: '#F5F9F4', name: '現地で稼ぎながら滞在継続', desc: 'ワーキングホリデービザを活用。高時給の農業・工場・カフェで貯金しながら経験を積む' }
            ],
            cities: [
                { flag: '🇵🇭', name: 'セブ島', tag: 'スタート地点' },
                { flag: '🇦🇺', name: 'ブリスベン', tag: '日本人少なめ' },
                { flag: '🇦🇺', name: 'ゴールドコースト', tag: 'ビーチ×仕事' }
            ],
            budget: '120〜220万円',
            duration: '6ヶ月〜1.5年',
            tips: 'フィリピンでの語学学校は「認定校」を選ぶことが重要。学校選びを誤ると効果が半減します。エージェントを通じて優良校を選びましょう。'
        };
    }
    // 3. 出稼ぎ×節約ワーホリ（お金を稼ぎたい＋行動力あり）
    else if ((a.goal === 'work' || a.after === 'money') && (a.type === 'active' || a.type === 'planner') && a.eng !== 'zero') {
        plan = {
            badge: '稼ぎながら英語を身につける',
            title: '出稼ぎワーホリ',
            titleSub: 'ローカルジョブ直行・高収入プラン',
            subtitle: 'オーストラリア / カナダ ― セカンドビザ活用',
            counseling: `行動力と一定の英語力があるあなたには<strong>語学学校は最小限（1〜2ヶ月）</strong>でOK。渡航後すぐにカフェ・農業・ホテル・日系企業などの現地ジョブにアプライしましょう。特にオーストラリアは<strong>最低賃金が時給約2,200円（AUD23〜）</strong>で、農業・工場のセカンドビザ業務と組み合わせれば年間300〜500万円の貯蓄も現実的。キャリアブランクを作らず帰国後の転職活動に活かせます。`,
            scores: [
                { label: '収入獲得力', val: 95, color: 'var(--rose-deep)' },
                { label: '英語上達速度', val: 75, color: 'var(--gold)' },
                { label: 'コストパフォーマンス', val: 88, color: 'var(--sage)' },
                { label: 'キャリア向上度', val: 70, color: 'var(--sky)' }
            ],
            planItems: [
                { icon: '🗣️', bg: '#FEF1F1', name: '語学学校 1〜2ヶ月（最小限）', desc: '英語の生活語彙をすばやく習得。コネクションと仕事探しの拠点づくりが目的' },
                { icon: '🧑‍🍳', bg: '#FFF8E7', name: 'ローカルジョブに即アプライ', desc: 'カフェ・レストラン・農業・ホテル清掃など。時給AUD23〜27が相場' },
                { icon: '🌾', bg: '#F5F9F4', name: 'セカンドワーホリを狙う（豪州のみ）', desc: '農業等の指定業務88日で2年目ビザ取得。帰国を延ばして貯金を最大化' }
            ],
            cities: [
                { flag: '🇦🇺', name: 'パース', tag: '高賃金・仕事豊富' },
                { flag: '🇦🇺', name: 'ケアンズ', tag: '農業×観光リゾート' },
                { flag: '🇨🇦', name: 'バンクーバー', tag: '日系企業が多い' }
            ],
            budget: '100〜180万円',
            duration: '1〜2年',
            tips: '渡航前にFarm仕事リストや農業エリア（バンダバーグ等）を事前にリサーチしておくと現地でのロスが減ります。JAM（日本人支援センター）の活用も◎'
        };
    }
    // 4. 英語留学×自己成長（語学上達・自分を変えたい）
    else if (a.goal === 'english' || a.goal === 'reset' || a.after === 'growth') {
        plan = {
            badge: '自分を変える留学',
            title: '王道語学留学',
            titleSub: '語学×自己成長フルコースプラン',
            subtitle: 'オーストラリア / カナダ ― 語学学校3〜6ヶ月',
            counseling: `英語力向上と自己成長を目指すあなたには、まず<strong>3〜6ヶ月間の語学学校</strong>を強くすすめます。世界中から集まった留学生たちとの出会いが、あなたの世界観を大きく広げてくれます。語学学校のあとはワーキングホリデーに移行して現地での就労体験を。<strong>英語ができる・海外で働けた</strong>という事実は、帰国後の転職市場で明らかな差別化になります。焦らず、でも<strong>本気で</strong>取り組んでください。`,
            scores: [
                { label: '英語上達速度', val: 90, color: 'var(--rose-deep)' },
                { label: '自己成長度', val: 95, color: 'var(--gold)' },
                { label: '心理的安全性', val: 80, color: 'var(--sage)' },
                { label: 'キャリア向上度', val: 72, color: 'var(--sky)' }
            ],
            planItems: [
                { icon: '📚', bg: '#FEF1F1', name: '語学学校 3〜6ヶ月', desc: '集中英語コース。General EnglishからIELTS対策まで目的に合わせて選択可能' },
                { icon: '🌟', bg: '#FFF8E7', name: 'ホームステイ or シェアハウス', desc: '現地の文化・生活を体験。語学力と並行して「生きた英語」を習得' },
                { icon: '💼', bg: '#F5F9F4', name: '語学後→ワーホリに移行', desc: '英語力がついた状態でバイト・仕事を開始。語学費用を少し回収しながら継続' }
            ],
            cities: [
                { flag: '🇦🇺', name: 'メルボルン', tag: 'オシャレ×多国籍' },
                { flag: '🇦🇺', name: 'バイロンベイ', tag: 'ナチュラル×自由' },
                { flag: '🇨🇦', name: 'バンクーバー', tag: '自然×都会の両立' }
            ],
            budget: '150〜250万円',
            duration: '6ヶ月〜1年',
            tips: '語学学校の最初のクラス分けテストは非常に重要。渡航前に少しでも勉強しておくと上のクラスに入れて吸収量が格段に変わります。'
        };
    }
    // 5. デフォルト（バランス型）
    else {
        plan = {
            badge: 'バランス型おすすめプラン',
            title: '自由設計ワーホリ',
            titleSub: 'あなただけのオリジナルルート',
            subtitle: 'オーストラリア or カナダ ― フレキシブルプラン',
            counseling: `あなたの回答は特定の方向に偏らない<strong>バランス型</strong>。それはむしろ、選択肢が広いということ。語学・仕事・旅行・自己成長をミックスした<strong>ワーキングホリデーが最も柔軟に対応できる選択</strong>です。まず3ヶ月語学学校でコネクションを作り、そこから仕事・旅行・学習と自分のペースで展開していきましょう。正解は一つじゃない。あなた自身が作っていくプランが一番です。`,
            scores: [
                { label: '自由度・柔軟性', val: 95, color: 'var(--rose-deep)' },
                { label: '英語上達速度', val: 78, color: 'var(--gold)' },
                { label: '自己成長度', val: 85, color: 'var(--sage)' },
                { label: 'コストパフォーマンス', val: 80, color: 'var(--sky)' }
            ],
            planItems: [
                { icon: '✈️', bg: '#FEF1F1', name: '語学学校 2〜3ヶ月からスタート', desc: '友達・コネクション作りが最初のミッション。ここが後の展開を左右する' },
                { icon: '🔄', bg: '#F5F9F4', name: '仕事・旅行・学習を自由にミックス', desc: 'ワーホリビザの特権を最大活用。農業・カフェ・旅行と自在にアレンジ可能' },
                { icon: '🌱', bg: '#F0F5F9', name: 'キャリアに活かせる体験を積む', desc: '語学力＋海外就労経験は帰国後の転職市場で強力なアドバンテージに' }
            ],
            cities: [
                { flag: '🇦🇺', name: 'メルボルン', tag: '生活しやすい' },
                { flag: '🇨🇦', name: 'バンクーバー', tag: '自然×都市' },
                { flag: '🇦🇺', name: 'シドニー', tag: '活気と多様性' }
            ],
            budget: '130〜220万円',
            duration: '6ヶ月〜1年',
            tips: '出発前に「何を達成したら成功か」を1〜3個決めておくこと。目標が明確な人とそうでない人では、帰国時の充実度に大きな差が出ます。'
        };
    }

    // ─── DOM更新 ───
    document.getElementById('res-badge').textContent = plan.badge;
    document.getElementById('res-title').innerHTML = `<strong>${plan.title}</strong><br><small style="font-size:1rem;font-weight:300;color:var(--text-mid)">${plan.titleSub}</small>`;
    document.getElementById('res-subtitle').textContent = plan.subtitle;
    document.getElementById('res-counseling').innerHTML = plan.counseling;

    // Score bars
    const sb = document.getElementById('score-bars');
    sb.innerHTML = plan.scores.map(s => `
        <div class="score-row">
            <div class="score-label">${s.label}</div>
            <div class="score-bar-track">
                <div class="score-bar-fill" style="background:${s.color};width:0%" data-val="${s.val}"></div>
            </div>
            <div class="score-val">${s.val}</div>
        </div>
    `).join('');

    setTimeout(() => {
        document.querySelectorAll('.score-bar-fill').forEach(el => {
            el.style.width = el.dataset.val + '%';
        });
    }, 200);

    // Plan items
    document.getElementById('res-plan-items').innerHTML = plan.planItems.map(p => `
        <div class="plan-item">
            <div class="plan-icon" style="background:${p.bg}">${p.icon}</div>
            <div class="plan-item-content">
                <div class="plan-item-name">${p.name}</div>
                <div class="plan-item-desc">${p.desc}</div>
            </div>
        </div>
    `).join('');

    // Cities
    document.getElementById('res-cities').innerHTML = plan.cities.map(c => `
        <div class="city-card">
            <div class="city-flag">${c.flag}</div>
            <div class="city-name">${c.name}</div>
            <div class="city-tag">${c.tag}</div>
        </div>
    `).join('');

    // Info
    document.getElementById('res-info-row').innerHTML = `
        <div class="info-chip">
            <div class="info-chip-label">Estimated Budget</div>
            <div class="info-chip-value" style="font-size:1.1rem">${plan.budget}</div>
        </div>
        <div class="info-chip">
            <div class="info-chip-label">Recommended Stay</div>
            <div class="info-chip-value" style="font-size:1.1rem">${plan.duration}</div>
        </div>
    `;

    document.getElementById('res-tips-text').textContent = plan.tips;
}

function resetQuiz() {
    current = 0;
    answers = {};
    document.getElementById('result-screen').style.display = 'none';
    document.getElementById('quiz-screen').style.display = 'block';
    render();
}

// Init
render();
</script>
</body>
</html>
